{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/responsive-report.schema.json",
  "title": "Responsive Testing Report",
  "description": "Normalized report contract for the responsive-testing Agent Skill.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill",
    "generated_at",
    "framework",
    "target",
    "command",
    "reused_tests",
    "new_tests",
    "viewports",
    "results",
    "summary",
    "findings",
    "artifacts",
    "next_actions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "skill": {
      "type": "string",
      "const": "responsive-testing"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "framework": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "reused_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "new_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "viewports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/viewport"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/result"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "width",
        "height",
        "category"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test",
        "viewport",
        "status",
        "duration_ms",
        "notes",
        "artifacts"
      ],
      "properties": {
        "test": {
          "type": "string",
          "minLength": 1
        },
        "viewport": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "skipped"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "passed",
                  "failed"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "artifacts": {
                "type": "array",
                "minItems": 1,
                "contains": {
                  "type": "string",
                  "pattern": "\\.(png|jpg|jpeg|gif|webp|svg)$"
                }
              }
            }
          }
        }
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_results",
        "passed",
        "failed",
        "skipped",
        "viewports_tested"
      ],
      "properties": {
        "total_results": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "viewports_tested": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "viewport",
        "area",
        "message",
        "artifact"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "minLength": 1
        },
        "viewport": {
          "type": "string",
          "minLength": 1
        },
        "area": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "artifact": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
